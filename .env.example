# Application
DEBUG=false
APP_NAME=Land Cases Search API
LOG_LEVEL=INFO

# Security
ADMIN_TOKEN=change_this_in_production
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Database
DATABASE_URL=sqlite:///./land_cases.db
# For PostgreSQL: postgresql://user:password@localhost/land_cases

# Redis (optional, for caching)
REDIS_URL=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE_MB=50

# CORS
CORS_ORIGINS=["*"]
# ==================== EMAIL CONFIGURATION ====================

# SMTP Server Settings
# For Gmail:
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your_email@gmail.com
#   SMTP_PASSWORD=your_app_password (not your regular password)
#
# For Outlook:
#   SMTP_SERVER=smtp.outlook.com
#   SMTP_PORT=587
#
# For SendGrid:
#   SMTP_SERVER=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=your_sendgrid_api_key

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email Display Settings
SENDER_EMAIL=noreply@bhoomi.local
SENDER_NAME=Bhoomi Land Cases

# Enable email functionality
ENABLE_EMAIL=true

# Email Verification Settings (in hours)
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=24